{
  "name": "mikroliving-backend",
  "version": "1.0.0",
  "description": "MikroLiving CMS Backend — Node.js + Express + MySQL",
  "main": "src/index.js",
  "scripts": {
    "dev": "node src/index.js",
    "dev:watch": "node --watch src/index.js",
    "dev:web": "next dev",
    "build": "next build",
    "build:web": "next build",
    "start:api": "node src/index.js",
    "start:api:prod": "node scripts/start-api.js",
    "start:web": "node scripts/start-web-local.js",
    "start:web:standalone": "node .next/standalone/server.js",
    "start": "node src/index.js",
    "db:migrate": "node src/config/migrate.js",
    "db:seed": "node src/config/seed.js",
    "db:reset": "node src/config/migrate.js && node src/config/seed.js",
    "db:wait": "node scripts/wait-for-db.js",
    "start:web:local": "node scripts/start-web-local.js",
    "start-local": "node scripts/start-local.js",
    "stop-local": "node scripts/stop-local.js",
    "restart-local": "node scripts/restart-local.js"
  },
  "dependencies": {
    "autoprefixer": "^10.4.20",
    "bcryptjs": "^2.4.3",
    "cloudinary": "^1.41.3",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-async-errors": "^3.1.1",
    "express-rate-limit": "^7.3.1",
    "express-validator": "^7.1.0",
    "framer-motion": "^11.11.17",
    "gsap": "^3.12.5",
    "helmet": "^7.1.0",
    "joi": "^17.13.1",
    "jsonwebtoken": "^9.0.2",
    "lucide-react": "^0.468.0",
    "morgan": "^1.10.0",
    "multer": "^2.1.1",
    "multer-storage-cloudinary": "^4.0.0",
    "mysql2": "^3.9.7",
    "next": "^14.2.30",
    "postcss": "^8.4.49",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "sequelize": "^6.37.3",
    "sharp": "^0.33.4",
    "slugify": "^1.6.6",
    "tailwindcss": "^3.4.17",
    "winston": "^3.13.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "nodemon": "^3.1.3",
    "typescript": "6.0.2"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
