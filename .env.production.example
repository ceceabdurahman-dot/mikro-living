# ------------------------------------------------------------
# MikroLiving production environment
# Copy this file to .env.production before deploying
# ------------------------------------------------------------

# App
NODE_ENV=production
PORT=5000
API_PREFIX=/api/v1

# Public web URLs
NEXT_PUBLIC_SITE_URL=https://mikroliving.id
NEXT_PUBLIC_API_URL=https://mikroliving.id/api/v1
API_PROXY_TARGET=https://your-live-backend.example.com/api/v1

# Database
DB_HOST=db
DB_PORT=3306
DB_NAME=mikro_living
DB_USER=mikro_user
DB_PASSWORD=change_me
DB_POOL_MAX=10
DB_POOL_MIN=2
DB_WAIT_MAX_RETRIES=40
DB_WAIT_RETRY_DELAY_MS=3000
AUTO_RUN_MIGRATIONS=true

# MySQL container bootstrap
# Keep this when using the bundled `db` service.
# In managed-database mode, `MYSQL_ROOT_PASSWORD` is unused.
MYSQL_ROOT_PASSWORD=change_root_password

# Auth
JWT_SECRET=replace_with_a_long_random_secret_min_32_chars
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=replace_with_a_second_long_random_secret
JWT_REFRESH_EXPIRES_IN=30d

# Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
CLOUDINARY_FOLDER=mikroliving

# CORS
ALLOWED_ORIGINS=https://mikroliving.id,https://www.mikroliving.id

# Rate limit
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# Seed admin
ADMIN_EMAIL=admin@mikroliving.id
ADMIN_PASSWORD=ChangeThisAdminPassword123!
ADMIN_NAME=MikroLiving Admin

# Optional SMTP
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=MikroLiving <noreply@mikroliving.id>
