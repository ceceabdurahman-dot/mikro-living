# ============================================================
#  MikroLiving Backend — Environment Variables
#  Salin file ini menjadi .env dan isi nilainya
# ============================================================

# ----- Server -----
NODE_ENV=development
PORT=5000
API_PREFIX=/api/v1

# ----- Database MySQL -----
DB_HOST=localhost
DB_PORT=3306
DB_NAME=mikro-living_db
DB_USER=root
DB_PASSWORD=your_mysql_password
DB_POOL_MAX=10
DB_POOL_MIN=2

# ----- JWT Authentication -----
JWT_SECRET=your_super_secret_jwt_key_min_32_chars
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your_refresh_secret_key
JWT_REFRESH_EXPIRES_IN=30d

# ----- Cloudinary (Image CDN) -----
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
CLOUDINARY_FOLDER=mikroliving

# ----- CORS -----
ALLOWED_ORIGINS=http://localhost:3000,https://mikroliving.com,https://www.mikroliving.com

# ----- Rate Limiting -----
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# ----- CMS Admin -----
ADMIN_EMAIL=admin@mikroliving.com
ADMIN_PASSWORD=Admin@Mikro2024!
ADMIN_NAME=MikroLiving Admin

# ----- Email (optional, untuk notifikasi) -----
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=noreply@mikroliving.com
SMTP_PASS=your_smtp_password
EMAIL_FROM=MikroLiving <noreply@mikroliving.com>
